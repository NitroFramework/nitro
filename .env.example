# Application
APP_NAME="NitroPHP"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Database — SQLite by default (zero setup; `nitro migrate` creates the file).
DB_CONNECTION=sqlite
# DB_DATABASE=/absolute/path/to/database.sqlite   # defaults to database/database.sqlite

# To use MySQL instead, comment the two lines above and uncomment these:
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=nitro
# DB_USERNAME=root
# DB_PASSWORD=

# Query Logging
DB_LOG_QUERIES=false