# Treat bundled front-end assets as vendored/generated so GitHub Linguist
# reports the repo's actual language (PHP) instead of the theme's CSS/JS.
public/assets/**     linguist-vendored
public/js/vendor/**  linguist-vendored
public/css/**        linguist-vendored
*.min.css            linguist-vendored
*.min.js             linguist-vendored
*.map                linguist-generated

# Framework runtime scripts shipped into public/ are vendored, not app code.
public/js/hx-component.js  linguist-vendored
public/js/livewire.js      linguist-vendored

# Count Blade templates as PHP (Linguist tags them as a separate "Blade"
# language by default, which starves the PHP stat).
*.blade.php  linguist-language=PHP
