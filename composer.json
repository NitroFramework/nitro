{
    "name": "nitro/nitro",
    "description": "The NitroPHP application skeleton.",
    "type": "project",
    "license": "MIT",
    "homepage": "https://github.com/NitroFramework/nitro",
    "authors": [
        {
            "name": "ZeeshanX4",
            "homepage": "https://github.com/ZeeshanX4",
            "role": "Developer"
        }
    ],
    "support": {
        "issues": "https://github.com/NitroFramework/nitro/issues",
        "source": "https://github.com/NitroFramework/nitro"
    },
    "require": {
        "php": "^8.2",
        "nitro/framework": "^0.3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Seeders\\": "database/seeders/",
            "Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "scripts": {
        "post-create-project-cmd": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php nitro key:generate"
        ],
        "test": "vendor/bin/phpunit --testdox --colors=always"
    }
}
